alice : (+) {
          bob ! 0.6 : l1 . end,
          bob ! 0.3 : l2 .
                (+) {
                  bob ! 0.9 : l3 . end,
                  bob ! 0.1 : l4 . end
                },
          bob ! 0.1 : l5 . end
        }

bob : & {
        alice ? l1 . end,
        alice ? l2 . & { alice ? l3 . end }
      }

